{
  "name": "clickcontext",
  "version": "0.1.12",
  "description": "Select a live UI element in a localhost app and ask your AI IDE about it — grounded in real DOM, accessibility, React component stack, and source.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gautham-psnl/clickcontext.git"
  },
  "homepage": "https://github.com/gautham-psnl/clickcontext#readme",
  "bugs": {
    "url": "https://github.com/gautham-psnl/clickcontext/issues"
  },
  "keywords": [
    "mcp",
    "devtools",
    "react",
    "source-map",
    "component-inspector",
    "ai-ide",
    "bookmarklet",
    "accessibility",
    "dom",
    "clickcontext"
  ],
  "bin": {
    "clickcontext": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "shared"
  ],
  "scripts": {
    "build": "node build.mjs",
    "build:bookmarklet": "node bookmarklet/build.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "daemon": "tsx cli/src/cli.ts daemon",
    "mcp": "tsx cli/src/cli.ts mcp"
  },
  "devDependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^20.14.0",
    "dom-accessibility-api": "^0.7.0",
    "esbuild": "^0.23.0",
    "jsdom": "^24.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
