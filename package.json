{
  "name": "clickcontext",
  "version": "0.1.0",
  "description": "Select a live UI element in a localhost app and ask your AI IDE about it — grounded in real DOM, accessibility, React component stack, and source.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "clickcontext": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "workspaces": ["shared"],
  "scripts": {
    "build": "node build.mjs",
    "build:bookmarklet": "node bookmarklet/build.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "daemon": "tsx cli/src/cli.ts daemon",
    "mcp": "tsx cli/src/cli.ts mcp"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "dom-accessibility-api": "^0.7.0",
    "esbuild": "^0.23.0",
    "jsdom": "^24.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
