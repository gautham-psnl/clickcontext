\f3\fs24 \cf0 \
\pard\pardeftab720\sa160\pardirnatural\partightenfactor0

\f0\b\fs22 \cf0 Note: 
\f2\b0 _debugStack is populated on real localhost dev servers (Vite, CRA, Next.js dev). It is stripped in production builds, CodeSandbox, and some hosted sandboxes. The regex filters for lines containing /src/ and excludes node_modules.\

\f0\b Next.js specific: 
\f2\b0 Next.js may use webpack-internal:// paths instead of /src/ paths in stack traces. The parser needs a fallback pattern for this \'97 identified as a known issue to fix before shipping.\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f3\fs24 \cf0 \
\pard\pardeftab720\pardirnatural\partightenfactor0

\f0\b\fs36 \cf2 The Capture Function\
\pard\pardeftab720\sa120\pardirnatural\partightenfactor0

\f2\b0\fs22 \cf0 The complete captureUIContext() function runs inside the Chrome extension content script. It attempts all four layers, marks unavailable ones, and returns a single merged object.\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f3\fs24 \cf0 function captureUIContext(el) \{\
\
  // Layer 1 \'97 DOM\
  const dom = \{\
    html: el.outerHTML,\
    tag: el.tagName,\
    attributes: Object.fromEntries([...el.attributes].map(a => [a.name, a.value])),\
    styles: \{\
      display: getComputedStyle(el).display,\
      opacity: getComputedStyle(el).opacity,\
      pointerEvents: getComputedStyle(el).pointerEvents,\
      visibility: getComputedStyle(el).visibility,\
    \}\
  \}\
\
  // Layer 2 \'97 Accessibility\
  const accessibility = \{\
    role: el.getAttribute('role') || el.tagName.toLowerCase(),\
    name: el.getAttribute('aria-label') || el.textContent.trim().slice(0, 50),\
    disabled: el.hasAttribute('disabled'),\
    ariaHidden: el.getAttribute('aria-hidden') === 'true',\
  \}\
\
  // Layer 3 \'97 React Fiber\
  const component = \{ available: false \}\
  const fiberKey = Object.keys(el).find(k => k.startsWith('__reactFiber'))\
\
  if (fiberKey) \{\
    component.available = true\
    component.framework = 'react'\
    component.stack = []\
\
    let fiber = el[fiberKey]\
    while (fiber) \{\
      const name = fiber.type?.name\
      if (name && typeof fiber.type !== 'string') \{\
\
        // hook states\
        let hooks = null\
        if (fiber._debugHookTypes) \{\
          hooks = []\
          let hookNode = fiber.memoizedState\
          fiber._debugHookTypes.forEach(type => \{\
            if (!hookNode) return\
            hooks.push(\{ type, value: hookNode.memoizedState \})\
            hookNode = hookNode.next\
          \})\
        \}\
\
        component.stack.push(\{\
          name,\
          props: fiber.memoizedProps,\
          hooks\
        \})\
      \}\
      fiber = fiber.return\
    \}\
  \}\
\
  // Layer 4 \'97 Source (works on real localhost, not CodeSandbox)\
  const source = \{ available: false \}\
  if (fiberKey) \{\
    let fiber = el[fiberKey]\
    while (fiber) \{\
      const stack = fiber._debugStack?.toString() || ''\
      const line = stack.split('\\n').find(l => l.includes('/src/') && !l.includes('node_modules'))\
      if (line) \{\
        const match = line.match(/at (\\S+) \\((.+):(\\d+):(\\d+)\\)/)\
        if (match) \{\
          source.available = true\
          source.file = match[2]\
          source.line = parseInt(match[3])\
          source.column = parseInt(match[4])\
          break\
        \}\
      \}\
      fiber = fiber.return\
    \}\
  \}\
\
  return \{\
    dom,\
    accessibility,\
    component,\
    source,\
    meta: \{\
      url: location.href,\
      layers: ['dom', 'accessibility',\
        component.available && 'component',\
        source.available && 'source'\
      ].filter(Boolean)\
    \}\
  \}\
\}\
\
// Run it\
console.log(captureUIContext(document.querySelector('h1')))
