{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@ui/shared": ["shared/src/index.ts"],
      "@ui/shared/*": ["shared/src/*"]
    }
  },
  "include": ["shared", "daemon", "mcp", "bookmarklet", "test"]
}
